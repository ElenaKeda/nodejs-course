<%- include('../includes/head.ejs') %>

  <body>
    <%- include('../includes/navigation.ejs') %>
    <main>
      <% if (orders.length > 0) { %>
        <ul class="cart">
          <% orders.forEach(order => { %>
            <li class="cart__item">
              <h3>
                Order # <%= order._id %>
              </h3>
              <ul>
                <% order.items.forEach(product => { %>
                  <li>
                    <%= product.title %> (<%= product.quantity %>) -  $<%= product.price %> (for 1 peace)
                  </li>
                <% }) %>
              </ul>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <h1>Nothing here!</h1>
      <% } %>  
    </main>
<%- include('../includes/end.ejs') %>