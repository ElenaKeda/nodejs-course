<%- include('../includes/head.ejs') %>

  <body>
    <%- include('../includes/navigation.ejs') %>
    <main>
      <% if (orders.length > 0) { %>
        <ul class="cart">
          <% orders.forEach(order => { %>
            <li class="cart__item">
              <h3>
                # <%= order.id %>
              </h3>
              <ul>
                <% order.products.forEach(product => { %>
                  <li>
                    <%= product.title %> - (<%= product.orderItem.quantity %>)
                  </li>
                <% }) %>
              </ul>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <h1>Nothing here!</h1>
      <% } %>  
    </main>
<%- include('../includes/end.ejs') %>